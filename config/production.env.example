# render-open-forge — Production Configuration Template
# Copy to .env and populate with real values before deploying.

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forge:password@localhost:5432/forge?sslmode=require

# Connection pooling: use PgBouncer sidecar in production
# Point DATABASE_URL at PgBouncer (default port 6432), which forwards to Postgres.
# PGBOUNCER_URL=postgresql://forge:password@localhost:6432/forge
# Recommended pool_mode=transaction, max_client_conn=200, default_pool_size=20

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# Redis persistence: enable AOF for durability (set in redis.conf or via CLI)
# appendonly yes
# appendfsync everysec
# auto-aof-rewrite-percentage 100
# auto-aof-rewrite-min-size 64mb

# ─── Forgejo ───────────────────────────────────────────────────────────
FORGEJO_INTERNAL_URL=http://forgejo:3000
FORGEJO_PUBLIC_URL=https://forge.example.com
FORGEJO_AGENT_TOKEN=<admin-token>
FORGEJO_WEBHOOK_SECRET=<random-secret>
# Set to "true" only in dev: FORGEJO_WEBHOOK_ALLOW_UNSIGNED=true

# ─── AI Provider ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Sandbox ───────────────────────────────────────────────────────────
SANDBOX_SERVICE_HOST=sandbox:3001
SANDBOX_SHARED_SECRET=<random-secret>
SANDBOX_SESSION_SECRET=<random-secret>

# ─── Auth / Security ──────────────────────────────────────────────────
AUTH_SECRET=<random-32-byte-hex>
CSRF_SECRET=<random-32-byte-hex>

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=100

# ─── OAuth (external forge sync) ──────────────────────────────────────
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITLAB_APPLICATION_ID=
GITLAB_APPLICATION_SECRET=
# Optional: self-hosted GitLab URL (defaults to https://gitlab.com)
# GITLAB_URL=https://gitlab.example.com

# ─── Webhook secrets (external forge events) ─────────────────────────
# Set these to verify incoming webhook payloads from external forges.
# If unset, all webhooks are accepted (only safe for development).
# GITHUB_WEBHOOK_SECRET=<random-secret>
# GITLAB_WEBHOOK_SECRET=<random-secret>

# ─── SSE / Streaming ──────────────────────────────────────────────────
# Max concurrent SSE connections per server instance
SSE_MAX_CONNECTIONS=500
# Connection idle timeout (ms) — close idle SSE after this
SSE_IDLE_TIMEOUT_MS=300000

# ─── Performance Tuning ───────────────────────────────────────────────
# Sandbox warm pool: pre-provision N containers for faster cold starts
# SANDBOX_WARM_POOL_SIZE=5

# Model response caching: cache identical prompts for N seconds
# MODEL_CACHE_TTL_SEC=0

# DB index recommendations (run EXPLAIN ANALYZE on slow queries):
#   CREATE INDEX idx_sessions_user ON sessions (user_id, updated_at DESC);
#   CREATE INDEX idx_agent_runs_session ON agent_runs (session_id, created_at DESC);
#   CREATE INDEX idx_ci_events_session ON ci_events (session_id, created_at DESC);
#   CREATE INDEX idx_chat_messages_chat ON chat_messages (chat_id, created_at ASC);
