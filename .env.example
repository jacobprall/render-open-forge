# ─── OpenForge — Local Development ────────────────────────────────────────────
# Copy to `.env` at the repo root. Symlinks (apps/web/.env, apps/agent/.env)
# point here so every process picks up the same values.

# ─── Database & Redis ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://forge:forge@localhost:5433/forge_app
REDIS_URL=redis://localhost:6380

# ─── GitHub OAuth (primary auth + repo access) ───────────────────────────────
# Create a GitHub OAuth App: https://github.com/settings/developers
# Callback URL: http://localhost:4000/api/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optional: a GitHub PAT for server-side operations (webhook registration, etc.)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
AUTH_SECRET=                       # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:4000

# ─── Admin account (auto-created on first startup) ───────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                    # Choose a strong password

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # Required — at least one LLM provider
OPENAI_API_KEY=                    # Optional fallback
# AES-256-GCM key for encrypting user-supplied API keys in the database.
# Must match across openforge-web and openforge-agent.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Sandbox (isolated code execution) ────────────────────────────────────────
SANDBOX_SERVICE_HOST=localhost:3001
SANDBOX_SHARED_SECRET=             # Shared secret for sandbox auth
SANDBOX_SESSION_SECRET=            # Per-session binding tokens

# ─── CI Runner (Render Workflows) ────────────────────────────────────────────
CI_RUNNER_MODE=local               # "local" for dev, "render" for production
CI_RUNNER_SECRET=                  # Shared secret for CI result callbacks
RENDER_API_KEY=                    # Render API key (production only)
RENDER_CI_WORKFLOW_SLUG=openforge-ci

# ─── Forgejo (optional — only if using self-hosted git) ──────────────────────
# FORGEJO_INTERNAL_URL=http://localhost:3000
# FORGEJO_EXTERNAL_URL=http://localhost:3000
# FORGEJO_SANDBOX_URL=http://forgejo:3000
# FORGEJO_AGENT_TOKEN=
# FORGEJO_OAUTH_CLIENT_ID=
# FORGEJO_OAUTH_CLIENT_SECRET=
