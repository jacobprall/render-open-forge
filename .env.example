# ─── Single source of truth for local dev ────────────────────────────────────
# Copy this file to `.env` at the repo root. Per-package config is loaded via
# symlinks: apps/web/.env, apps/web/.env.local, apps/agent/.env all point
# back to this same file. Edit once, every process picks it up.

# Database
DATABASE_URL=postgres://forge:forge@localhost:5433/forge_app

# Redis
REDIS_URL=redis://localhost:6380

# Forgejo
FORGEJO_INTERNAL_URL=http://localhost:3000
FORGEJO_EXTERNAL_URL=http://localhost:3000
# Hostname the sandbox container uses to reach Forgejo. Required when the agent
# clones repos from inside Docker (otherwise `localhost` is the container itself).
FORGEJO_SANDBOX_URL=http://forgejo:3000
FORGEJO_AGENT_TOKEN=               # Created by setup script
FORGEJO_OAUTH_CLIENT_ID=           # Created by setup script
FORGEJO_OAUTH_CLIENT_SECRET=       # Created by setup script
FORGEJO_WEBHOOK_ALLOW_UNSIGNED=true

# NextAuth
AUTH_SECRET=                       # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:4000
SESSION_SECRET=                    # Generate with: openssl rand -base64 32

# Initial admin (auto-created on first startup if users table is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                    # Choose a strong password

# Google / GitHub OAuth (configured as Forgejo auth sources)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# AI / LLM
ANTHROPIC_API_KEY=
# Optional fallback; UI-stored keys use ENCRYPTION_KEY and Postgres.
OPENAI_API_KEY=
# AES-256-GCM key for encrypting LLM API keys in the database (64 hex chars recommended).
# Must be the same value on forge-web and forge-agent when using UI-managed keys.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# CI Runner (Render Workflows)
CI_RUNNER_MODE=local               # "local" for dev, "render" for production
CI_RUNNER_SECRET=                  # Shared secret for CI result callbacks
RENDER_API_KEY=                    # Render API key (production only)
RENDER_CI_WORKFLOW_SLUG=forge-ci   # Render Workflow service slug

# Sandbox
SANDBOX_SERVICE_HOST=localhost:3001
SANDBOX_SHARED_SECRET=             # Shared secret for sandbox auth
SANDBOX_SESSION_SECRET=            # Secret for per-session binding tokens
