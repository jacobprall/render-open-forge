# Database
DATABASE_URL=postgres://forge:forge@localhost:5432/forge

# Redis
REDIS_URL=redis://localhost:6379

# Forgejo
FORGEJO_INTERNAL_URL=http://localhost:3000
FORGEJO_EXTERNAL_URL=http://localhost:3000
FORGEJO_AGENT_TOKEN=               # Created by setup script
FORGEJO_OAUTH_CLIENT_ID=           # Created by setup script
FORGEJO_OAUTH_CLIENT_SECRET=       # Created by setup script

# Session
SESSION_SECRET=change-me-in-production

# Google OAuth (configured as Forgejo auth source)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AI
ANTHROPIC_API_KEY=

# Sandbox (optional, for agent execution)
SANDBOX_SERVICE_HOST=
